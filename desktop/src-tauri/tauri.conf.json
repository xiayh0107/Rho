{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Rho",
  "version": "0.2.0-dev.2",
  "identifier": "org.yulab.rho",
  "build": {
    "frontendDist": "../../web"
  },
  "app": {
    "withGlobalTauri": false,
    "windows": [],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis"],
    "resources": {
      "../resources/runtime/": "resources/runtime/",
      "../resources/WebView2Loader.dll": "WebView2Loader.dll",
      "../../r/rho.bridge/": "resources/rho.bridge/"
    },
    "fileAssociations": [
      {
        "ext": ["Rproj"],
        "name": "R Project",
        "description": "R project opened with the Rho scientific runtime",
        "role": "Editor",
        "mimeType": "text/plain"
      }
    ],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.ico"
    ],
    "shortDescription": "Desktop launcher for the Rho scientific runtime",
    "longDescription": "Rho Desktop starts rho-server and projects its browser-based scientific control plane in a small system wrapper."
  }
}
