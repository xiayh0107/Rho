{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Rho",
  "version": "0.2.0-dev.2",
  "identifier": "org.yulab.rho",
  "build": {
    "frontendDist": "../dist"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "Rho",
        "width": 1440,
        "height": 900,
        "minWidth": 1024,
        "minHeight": 680,
        "center": true,
        "resizable": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis"],
    "resources": {
      "../resources/runtime/": "resources/runtime/",
      "../resources/WebView2Loader.dll": "WebView2Loader.dll"
    },
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.ico"
    ],
    "shortDescription": "An agent-native scientific workbench for R",
    "longDescription": "Rho is a lightweight R workbench with an Ark-backed live session and an aisdk-powered AI collaborator."
  }
}
